# ── Grafana (required) ────────────────────────────────────────────────────────
GRAFANA_URL=https://your-instance.grafana.net
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GRAFANA_DS_UID=your_postgres_datasource_uid

# ── Slack (required) ──────────────────────────────────────────────────────────
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Monday.com (optional — leave blank to skip ticket creation) ───────────────
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_TIMEOUT=15

# ── Database schema / table names ─────────────────────────────────────────────
# These map to the PostgreSQL tables queried via Grafana API proxy.
# Change these if your environment uses a different schema or table names.
DB_SCHEMA=public
DB_TABLE_WALLETS=credits-table
DB_TABLE_ORGS=org-table

# ── Poller behaviour ──────────────────────────────────────────────────────────
POLL_INTERVAL=60        # How often to query the DB, in seconds
REPEAT_AFTER=86400      # Re-alert interval for persistent low credits (seconds, default 24h)

# ── File paths ────────────────────────────────────────────────────────────────
LOG_FILE=~/slack-alerts/credit_poller.log
STATE_FILE=~/slack-alerts/credit_poller_state.json
