# ─────────────────────────────────────────────────────────────────────────────
# AIOS Alert Manager — Environment Configuration
# Copy this file to .env and fill in the real values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Grafana Cloud ────────────────────────────────────────────────────────────
# Service account token (starts with glsa_). Create in:
#   Grafana → Administration → Service accounts → Add service account → Add token
GRAFANA_URL=https://your-stack.grafana.net
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Data source: LOKI (used by the Loki edition only) ────────────────────────
# Numeric datasource ID of your Loki source (Grafana → Connections → Data sources)
LOKI_DS_ID=12

# ── Data source: AZURE MONITOR (used by the Azure edition only) ──────────────
# UID of the Azure Monitor datasource in Grafana
AZURE_DS_UID=xxxxxxxxxxxxxx
# Full Log Analytics workspace resource ID
#   Azure Portal → Log Analytics workspace → Properties → Resource ID
AZURE_RESOURCE=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.OperationalInsights/workspaces/<workspace>

# ── Kubernetes scope ─────────────────────────────────────────────────────────
NAMESPACE=ai-os-production
# Loki cluster label (Loki edition). Leave blank if the label no longer exists.
CLUSTER=cluster-name

# ── Slack ────────────────────────────────────────────────────────────────────
# Bot token (starts with xoxb-). Needs scopes: chat:write, channels:read, groups:read
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
# Channel IDs (NOT names). Right-click channel → View channel details → copy ID
ALERT_CHANNEL=C0XXXXXXXXX
REPORT_CHANNEL=C0XXXXXXXXX

# ── Behaviour ────────────────────────────────────────────────────────────────
POLL_SECONDS=30
# Azure Monitor ingestion delay buffer in seconds (Azure edition).
# Azure logs take ~60-120s to appear; query up to this many seconds ago.
INGEST_LAG_SEC=180
# Web UI port
UI_PORT=9002
# Auto-delete error count entries older than N days
COUNTS_MAX_DAYS=15
# Log file rotation
MAX_LOG_MB=300
MAX_LOG_DAYS=20

# ── Storage directory (where state/log/counts files live) ────────────────────
# Defaults to ./data if not set
DATA_DIR=./data
